# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# logs
*.log
logs/

# caches / temp
.cache/
.turbo/
.eslintcache
.stylelintcache
tmp/
temp/

# test artifacts
.nyc_output/
playwright-report/
test-results/

# editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# OS files
Thumbs.db
Desktop.ini

# patch / merge leftovers
*.orig
*.rej
